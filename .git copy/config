[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[remote "origin"]
	url = git@github.com:ramirezandreacarballo/bento-portfolio.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[remote "upstream"]
	url = git@github.com:DZELhub/dzel-bento-portfolio.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
